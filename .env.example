# Copy to .env for local development (docker-compose loads .env)

# Tenant API key (plaintext for dev; production uses hash in DB)
MENTOOL_DEV_API_KEY=dev-tenant-api-key-change-me

# JWT signing secret (use long random string; production: AWS SSM)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# DynamoDB
DYNAMODB_TABLE_NAME=men-tool-dev
DYNAMODB_ENDPOINT_URL=http://localhost:8000

# AWS (real AWS omit endpoint; use IAM role)
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=us-east-1

# Optional: SSM path for JWT in production (not used locally)
# JWT_SECRET_SSM_PATH=/men-tool/dev/jwt_secret

# Default tenant id
DEFAULT_TENANT_ID=mentool
