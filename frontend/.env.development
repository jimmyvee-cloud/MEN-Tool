# Leave empty in dev: browser calls /v1 on the same host:port as Vite (avoids broken
# Leave empty: browser calls /v1 on the dev server; Vite proxies to VITE_PROXY_API_TARGET
# (default https://api.infra-guys.com, or http://api:8000 in docker-compose when overridden).
# Set only to bypass the proxy (direct API URL, requires CORS on the API).
VITE_API_BASE_URL=
VITE_API_KEY=dev-tenant-api-key-change-me
VITE_TENANT_ID=mentool
# Same as root .env GOOGLE_OAUTH_CLIENT_ID when using npm run dev outside Docker
# VITE_GOOGLE_CLIENT_ID=
