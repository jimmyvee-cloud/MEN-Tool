# Copy to .env for local development (docker-compose loads .env)

# Tenant API key (plaintext for dev; production uses hash in DB)
MENTOOL_DEV_API_KEY=dev-tenant-api-key-change-me

# JWT signing secret (use long random string; production: AWS SSM)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# DynamoDB
DYNAMODB_TABLE_NAME=men-tool-dev
# Local DynamoDB Local only — omit for real AWS DynamoDB
DYNAMODB_ENDPOINT_URL=http://localhost:8817

# AWS — read by the API via pydantic-settings (process env or .env next to repo / backend / cwd).
# Production: prefer an IAM role on the host/task; otherwise set these in the container/process env.
# AWS_DEFAULT_REGION is accepted as an alias for AWS_REGION.
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=us-east-1

# Optional: SSM path for JWT in production (not used locally)
# JWT_SECRET_SSM_PATH=/men-tool/dev/jwt_secret

# Default tenant id
DEFAULT_TENANT_ID=mentool

# Google Sign-In: Web client ID (OAuth 2.0). Backend + docker-compose frontend read this.
# Also add authorized JS origins: http://localhost:5973 and your production URL.
GOOGLE_OAUTH_CLIENT_ID=

# Optional (scripts/seed.py): after a user registers, promote them to admin. Comma-separated. No default — safe for prod.
# SEED_PROMOTE_ADMIN_EMAILS=owner@yourdomain.com

# Optional: password for seeded dev admin admin@mentool.local (default in README if unset)
# SEED_ADMIN_PASSWORD=
